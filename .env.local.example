NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Opcional — só para o OAuth do Gmail (envio via Google).
# Sem isso, use caixas SMTP normalmente.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Opcional — necessário só para o rastreio de propostas (link público /s/{token}).
# Pegue em Supabase → Settings → API → service_role. NUNCA use prefixo NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — habilita o "Gerar cadência com IA".
# Pegue a chave em console.anthropic.com. ANTHROPIC_MODEL é opcional (default sonnet).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Necessário para a detecção automática de resposta (cron IMAP).
# Defina um valor secreto qualquer; a Vercel injeta como Authorization no cron.
CRON_SECRET=

# Opcional — provedor de enriquecimento de CNPJ. Vazio = BrasilAPI (grátis).
# Para plugar CNPJ.ws/ReceitaWS, use uma URL com {cnpj}, ex.: https://.../cnpj/{cnpj}
CNPJ_PROVIDER_URL=

# URL pública do app (ex.: https://contatia.vercel.app) — usada para montar os
# links rastreados de clique. Se vazio, usa VERCEL_URL automaticamente.
NEXT_PUBLIC_APP_URL=

# Token do webhook do Asaas (billing). Configure o mesmo valor no painel do Asaas
# como parâmetro ?token= da URL /api/webhooks/asaas.
ASAAS_WEBHOOK_TOKEN=

# --- Billing / transacional (padrão Quotaria) ---
# API do Asaas (gera a cobrança e o link de pagamento automaticamente)
ASAAS_API_KEY=
# Opcional: defina como "sandbox" para usar o ambiente de testes do Asaas
ASAAS_ENV=
# API transacional do Brevo (envio de fatura/lembrete)
BREVO_API_KEY=
# Remetente transacional
EMAIL_FROM=suporte@contatia.com.br
EMAIL_FROM_NAME=Contatia
